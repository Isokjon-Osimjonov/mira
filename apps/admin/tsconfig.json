{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"],
      "@mira/shared-types": ["../../libs/shared-types/src/index.ts"],
      "@mira/shared-utils": ["../../libs/shared-utils/src/index.ts"],
      "@mira/ui-config":    ["../../libs/ui-config/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
