{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "paths": {
      "~/*": ["./*"],
      "@mira/shared-types": ["../../libs/shared-types/src/index.ts"],
      "@mira/shared-utils": ["../../libs/shared-utils/src/index.ts"],
      "@mira/ui-config": ["../../libs/ui-config/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "android", "ios"]
}
