# ─── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/mira_db

# ─── JWT (min 32 chars each) ───────────────────
JWT_SECRET=change-this-minimum-32-characters-secret
JWT_REFRESH_SECRET=change-this-minimum-32-characters-refresh

# ─── Telegram Bot ──────────────────────────────
BOT_TOKEN=
BOT_USERNAME=mira_cosmetics_bot

# ─── Cloudinary ────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Exchange Rate API ─────────────────────────
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# ─── SMS Fallback (Eskiz.uz) ───────────────────
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ─── Server ────────────────────────────────────
PORT=4000
NODE_ENV=development
ADMIN_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
